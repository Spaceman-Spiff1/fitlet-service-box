# Replace every REPLACE_ME_* value before running install.sh.
# This file is intentionally generic so the public repo does not publish your real network layout.
TZ=REPLACE_ME_TZ
PUID=1000
PGID=1000
FITLET_IP=REPLACE_ME_FITLET_IP
WEBUI_PORT=8080
TORRENTING_PORT=49152
CONFIG_DIR=/srv/qbittorrent/config
DOWNLOADS_DIR=/srv/downloads
PROJECT_DIR=/opt/fitlet-service-box
# INSTALL_MODE values:
# auto        = use USB bundle when present, otherwise download what is missing
# bundle-only = refuse all package and image downloads during install
# online-only = ignore the USB bundle and install from the network
INSTALL_MODE=auto
QBITTORRENT_IMAGE=lscr.io/linuxserver/qbittorrent:latest
PUBLIC_IP_CHECK_URL=https://ifconfig.me
EXPECTED_DNS=REPLACE_ME_DNS_IP
EXPECTED_GATEWAY=REPLACE_ME_GATEWAY_IP
EXPECTED_NTP=REPLACE_ME_NTP_IP
EXPECTED_SUBNET=REPLACE_ME_SUBNET_CIDR
LAN_TEST_TARGET=REPLACE_ME_LAN_TEST_TARGET
BACKUP_DIR=/var/backups/fitlet-service-box
